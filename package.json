{
  "name": "lsm",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && bun build --production --target=bun --minify --outfile dist/index.js src/index.ts && bun build --production --target=bun --minify --outfile dist/cli.js src/cli.ts",
    "dev": "NODE_ENV=development bun --watch src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "table": "^6.9.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5"
  },
  "main": "dist/index.js"
}
